# ---------------------------- Application ----------------------------
BACKEND_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:5173

# NOTE: docker-compose.prod.yml's frontend build needs VITE_API_BASE_URL,
# VITE_APP_NAME, VITE_SENTRY_DSN, and VITE_SENTRY_ENVIRONMENT too (Vite
# bakes them in at build time) — but they must NOT be added to this file.
# Settings below ignores unrecognized keys (extra="ignore") specifically so
# this root .env can be shared with docker-compose's own env_file/build-arg
# interpolation without every infra-only key needing a matching Settings
# field — but VITE_-prefixed keys have no meaning to the backend either
# way. Export them in the shell instead before building — see
# frontend/.env.example for the values and docs/deployment/guide.md for the
# exact command.

# ---------------------------- Database ----------------------------
# Docker service hostname; swap to localhost when running the backend outside Docker
DATABASE_URL=postgresql+asyncpg://<db_username>:<db_password>@postgres:5432/<db_name>
# DATABASE_URL=postgresql+asyncpg://<db_username>:<db_password>@localhost:5433/<db_name>

POSTGRES_USER=<db_username>
POSTGRES_PASSWORD=<db_password>
POSTGRES_DB=<db_name>

# ---------------------------- JWT & Tokens ----------------------------
SECRET_KEY=<secret_key_here>
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_MINUTES=43200
JWT_ALGORITHM=HS256
RESET_TOKEN_EXPIRE_MINUTES=60

# ---------------------------- OAuth2 ----------------------------
GOOGLE_CLIENT_ID=<your_google_client_id>
GOOGLE_CLIENT_SECRET=<your_google_client_secret>
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/oauth2/callback/google

# ---------------------------- Redis & Caching ----------------------------
# Leave blank for no Redis auth (fine for local dev). For any deployment that
# publishes the Redis port or shares a network with untrusted services, set a
# strong password here — docker-compose.yml/docker-compose.prod.yml pass this
# to `redis-server --requirepass`.
REDIS_PASSWORD=

# Docker service hostname; swap to localhost when running Redis outside Docker.
# If REDIS_PASSWORD above is set, it must also be embedded here (redis-py and
# taskiq-redis both authenticate via the URL, not a separate setting):
#   REDIS_URL=redis://:<REDIS_PASSWORD>@redis:6379/0
REDIS_URL=redis://redis:6379/0
# REDIS_URL=redis://localhost:6380/0

CACHE_DEFAULT_TTL=300

# ---------------------------- Email ----------------------------
FROM_EMAIL=<your_google_email>
GMAIL_APP_PASSWORD=<your_gmail_app_password>

# Contact address shown in email footers and used as the Reply-To header.
# Optional — defaults to FROM_EMAIL if unset.
SUPPORT_EMAIL=<your_support_email>

# SMTP server used by emails/email_sender.py::SMTPEmailSender.
# Optional — default is Gmail's; override to point at another SMTP provider.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587

# Product name shown in email templates and API responses.
APP_NAME=ManifestCV

# ---------------------------- Login Protection ----------------------------
LOGIN_LOCKOUT_TIME=300
MAX_FAILED_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_TIME_PER_IP=300

# Higher than MAX_FAILED_LOGIN_ATTEMPTS since one IP can legitimately represent many users.
# Used to detect credential stuffing/spraying from a single source.
MAX_FAILED_LOGIN_ATTEMPTS_PER_IP=20

# ---------------------------- Rate Limiting ----------------------------
MAX_REQUESTS_PER_WINDOW=100
REQUEST_WINDOW_SECONDS=60

# ---------------------------- Logging ----------------------------
# DEBUG, INFO, WARNING, ERROR.
# Optional — defaults to INFO.
LOG_LEVEL=INFO

# ---------------------------- Environment ----------------------------
# "development" or "production".
# Optional — defaults to development.
# Production disables /docs, /redoc, and /openapi.json to reduce attack surface.
ENVIRONMENT=development

# ---------------------------- Reverse Proxy ----------------------------
# Comma-separated IP addresses of trusted reverse proxies (e.g. nginx).
# Leave empty unless a real proxy sits in front of FastAPI.
# Only trusted proxies can provide X-Forwarded-For client IP information.
TRUSTED_PROXY_IPS=

# ---------------------------- Error Monitoring ----------------------------
# Optional. Sentry-protocol DSN for the backend (works with Sentry itself,
# or a self-hosted Sentry-SDK-compatible server — see
# docs/error-monitoring/overview.md for the self-hosted Bugsink setup this
# template documents). Leave blank to disable entirely — no Sentry SDK call
# is ever made when unset.
SENTRY_DSN=

# Optional. Tag reported alongside every event (e.g. "production").
# Falls back to ENVIRONMENT above if unset.
SENTRY_ENVIRONMENT=

# The following BUGSINK_* variables configure the optional, opt-in
# self-hosted Bugsink service in docker-compose.yml/docker-compose.prod.yml
# (docker compose --profile monitoring up) — they are read directly by that
# container, not by the backend/frontend's own Settings. See
# docs/error-monitoring/overview.md for the full setup walkthrough
# (Bugsink's project DSN, generated after first login, is what actually
# goes into SENTRY_DSN above).

# Django's own secret key for the Bugsink service — distinct from this
# app's own SECRET_KEY above, unrelated purpose. Generate with, e.g.,
# `openssl rand -base64 50`.
BUGSINK_SECRET_KEY=<bugsink_secret_key_here>

# One-time admin login email created on Bugsink's first startup.
BUGSINK_SUPERUSER_EMAIL=<your_email>

# One-time admin login password created on Bugsink's first startup.
BUGSINK_SUPERUSER_PASSWORD=<bugsink_admin_password>

# The URL you'll actually open Bugsink's UI at.
BUGSINK_BASE_URL=http://localhost:8010

# ---------------------------- AI (Gemini) & Retrieval (Qdrant) ----------------------------
# ManifestCV. Get a key at https://aistudio.google.com/apikey — free tier available.
GEMINI_API_KEY=<your_gemini_api_key>

# Text generation model used to structure raw career input into Markdown.
# Optional — defaults to gemini-flash-latest (a self-updating alias).
GEMINI_MODEL=gemini-flash-latest

# Embedding model used for semantic search over knowledge base content.
# Optional — defaults to gemini-embedding-001.
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Self-hosted Qdrant (docker-compose.yml's qdrant service) — no signup, no API key.
# Docker service hostname; swap to localhost when running the backend outside Docker.
QDRANT_URL=http://qdrant:6333
# QDRANT_URL=http://localhost:6333