# ---------------------------- App Config ----------------------------
# Base URL for the backend, reached through NGINX
BACKEND_BASE_URL=http://localhost:8000

# Base URL for the frontend, served through NGINX
FRONTEND_BASE_URL=http://localhost:5173

# ---------------------------- Frontend Config ----------------------------
# Vite vars — read by the dev server (vite.config.ts's envDir points here)
# and, for the production image, baked in as build args by
# docker-compose.prod.yml (Compose interpolates ${VAR} from this same file).

# Backend base URL the frontend calls
VITE_API_BASE_URL=http://localhost:8000

# Product name shown in the UI (navbar, auth pages, document title)
VITE_APP_NAME=ManifestCV

# Sentry-protocol DSN for the frontend; blank disables error monitoring entirely
VITE_SENTRY_DSN=

# Tag reported alongside every event; falls back to Vite's own MODE if unset
VITE_SENTRY_ENVIRONMENT=

# ---------------------------- Database Config ----------------------------
# SQLAlchemy async database URL (Docker)
DATABASE_URL=postgresql+asyncpg://<db_username>:<db_password>@postgres:5432/<db_name>

# SQLAlchemy async database URL (running locally)
# DATABASE_URL=postgresql+asyncpg://<db_username>:<db_password>@localhost:5433/<db_name>

# PostgreSQL user
POSTGRES_USER=<db_username>

# PostgreSQL password
POSTGRES_PASSWORD=<db_password>

# PostgreSQL database name
POSTGRES_DB=<db_name>

# ---------------------------- JWT Config ----------------------------
# Secret key for JWT encoding
SECRET_KEY=<secret_key_here>

# JWT access token expiration in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=15

# JWT refresh token expiration in minutes
REFRESH_TOKEN_EXPIRE_MINUTES=43200

# JWT signing algorithm
JWT_ALGORITHM=HS256

# Password reset token expiration in minutes
RESET_TOKEN_EXPIRE_MINUTES=60

# ---------------------------- OAuth2 / Gmail Config ----------------------------
# Google OAuth2 client ID
GOOGLE_CLIENT_ID=<your_google_client_id>

# Google OAuth2 client secret
GOOGLE_CLIENT_SECRET=<your_google_client_secret>

# Google OAuth2 redirect URI after authentication
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/oauth2/callback/google

# ---------------------------- Redis Config ----------------------------
# Redis auth password — blank means no auth (fine for local dev); if set, must
# also be embedded in REDIS_URL below: redis://:<REDIS_PASSWORD>@redis:6379/0
REDIS_PASSWORD=

# Redis connection URL (Docker)
REDIS_URL=redis://redis:6379/0

# Redis connection URL (running locally; Redis still in Docker)
# REDIS_URL=redis://localhost:6380/0

# Default cache TTL in seconds
CACHE_DEFAULT_TTL=300

# ---------------------------- Email / SMTP Config ----------------------------
# Email address used for sending emails
FROM_EMAIL=<your_google_email>

# Gmail App password for sending email from the above account
GMAIL_APP_PASSWORD=<your_gmail_app_password>

# Contact address shown in email footers (Reply-To); defaults to FROM_EMAIL if unset
SUPPORT_EMAIL=<your_support_email>

# SMTP server override; defaults to Gmail's
# SMTP_HOST=smtp.gmail.com

# SMTP port override; defaults to 587 (STARTTLS)
# SMTP_PORT=587

# ---------------------------- App Name Config ----------------------------
# Product name shown in email branding and API responses
APP_NAME=ManifestCV

# ---------------------------- Rate Limiter Config ----------------------------
# Lockout time in seconds after failed login attempts
LOGIN_LOCKOUT_TIME=300

# Maximum allowed failed login attempts before lockout
MAX_FAILED_LOGIN_ATTEMPTS=5

# Lockout time in seconds for a single IP after too many failed logins across any accounts
LOGIN_LOCKOUT_TIME_PER_IP=300

# Maximum failed login attempts from a single IP across any accounts before that IP is locked out
MAX_FAILED_LOGIN_ATTEMPTS_PER_IP=20

# Maximum number of requests per window
MAX_REQUESTS_PER_WINDOW=100

# Duration of request window in seconds
REQUEST_WINDOW_SECONDS=60

# ---------------------------- Logging Config ----------------------------
# Application log level: DEBUG, INFO, WARNING, ERROR — defaults to INFO
LOG_LEVEL=INFO

# ---------------------------- Environment Config ----------------------------
# "development" or "production" — production disables /docs, /redoc, /openapi.json
ENVIRONMENT=development

# ---------------------------- Reverse Proxy Config ----------------------------
# Comma-separated trusted reverse proxy IPs; leave empty unless one sits in front of FastAPI
TRUSTED_PROXY_IPS=

# ---------------------------- Error Monitoring Config ----------------------------
# Sentry-protocol DSN for the backend; blank disables error monitoring entirely
SENTRY_DSN=

# Tag reported alongside every event; falls back to ENVIRONMENT if unset
SENTRY_ENVIRONMENT=

# Django's own secret key for the optional self-hosted Bugsink service
BUGSINK_SECRET_KEY=<bugsink_secret_key_here>

# One-time admin login email created on Bugsink's first startup
BUGSINK_SUPERUSER_EMAIL=<your_email>

# One-time admin login password created on Bugsink's first startup
BUGSINK_SUPERUSER_PASSWORD=<bugsink_admin_password>

# The URL Bugsink's UI is actually reachable at
BUGSINK_BASE_URL=http://localhost:8010

# ---------------------------- AI (Gemini) & Retrieval (Qdrant) ----------------------------
# Gemini API key — get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=<your_gemini_api_key>

# Text generation model for structuring raw career input into Markdown
GEMINI_MODEL=gemini-flash-latest

# Embedding model for semantic search over knowledge base content
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Self-hosted Qdrant URL (Docker service hostname)
QDRANT_URL=http://qdrant:6333
# QDRANT_URL=http://localhost:6333
